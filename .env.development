# Base del API AuthService (.NET): mismo host/puerto que la colección Postman (5025)
VITE_API_BASE=http://localhost:5025/api/v1

# API Node (MongoDB): transacciones, depósitos, cuentas — debe coincidir con PORT + BASE_PATH del servidor Sistema Bancario
VITE_BANKING_API_BASE=http://localhost:3000/SistemaBancarioAdmin/v1

# AuthController: api/v1/Auth/login, register, profile, etc.
VITE_AUTH_URL=http://localhost:5025/api/v1/Auth

# Compat (misma base; el código usa sobre todo VITE_API_BASE)
VITE_API_URL=http://localhost:5025/api/v1
VITE_PRODUCT_URL=http://localhost:5025/api/v1/admin
VITE_ADMIN_URL=http://localhost:5025/api/v1

VITE_APP_NAME=AuthServiceBanco
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development
